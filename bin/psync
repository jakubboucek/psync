#!/usr/bin/env php
<?php

declare(strict_types=1);

namespace JakubBoucek\Psync;

use Composer\InstalledVersions;
use Symfony\Component\Console\Application;

(static function (): void {
    // Locate the autoloader – so the package works both locally and as a `composer global` install.
    $candidates = [
        __DIR__ . '/../vendor/autoload.php',          // local development
        __DIR__ . '/../../../autoload.php',            // installed as a dependency
    ];
    foreach ($candidates as $file) {
        if (is_file($file)) {
            require $file;
            return;
        }
    }
    fwrite(STDERR, "Composer autoloader not found. Run `composer install`.\n");
    exit(1);
})();

$version = class_exists(InstalledVersions::class)
    ? (InstalledVersions::getPrettyVersion('jakubboucek/psync') ?? 'unknown')
    : 'unknown';

$app = new Application('psync', $version);

$app->addCommands([
    new Command\InstallCommand(),
    new Command\ReinstallCommand(),
    new Command\CompareCommand(),
    new Command\UploadCommand(),
    new Command\DownloadCommand(),
]);

/** @noinspection PhpUnhandledExceptionInspection */
$app->run();
