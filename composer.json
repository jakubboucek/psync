{
    "name": "jakubboucek/php-sync",
    "description": "Obousměrná rsync-podobná synchronizace souborů přes HTTP agenta pro legacy hostingy (jen FTP).",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Jakub Bouček",
            "email": "pan@jakubboucek.cz"
        }
    ],
    "require": {
        "php": ">=8.4",
        "ext-curl": "*",
        "ext-sodium": "*",
        "ext-zlib": "*",
        "symfony/console": "^7.1"
    },
    "autoload": {
        "psr-4": {
            "PhpSync\\": "src/"
        }
    },
    "bin": [
        "bin/php-sync"
    ],
    "config": {
        "sort-packages": true
    },
    "require-dev": {
        "nette/tester": "^2.5",
        "php-parallel-lint/php-parallel-lint": "^1.4",
        "phpstan/phpstan": "^2.2",
        "phpstan/phpstan-strict-rules": "^2.0"
    },
    "scripts": {
        "lint": "parallel-lint -e php,phpt src bin agent tests",
        "phpstan": "phpstan analyse --memory-limit=512M",
        "tester": "tester -C tests/Unit",
        "check": [
            "@lint",
            "@phpstan",
            "@tester"
        ]
    }
}
